{
  "name": "contrast-lens",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "vite",
    "build": "npm --prefix packages/engine run build && npm --prefix packages/browser-extension run build && npm --prefix packages/storybook-addon run build && npm --prefix packages/test-components run build",
    "test": "npm --prefix packages/engine run test",
    "typecheck": "npm --prefix packages/engine run typecheck && npm --prefix packages/browser-extension run typecheck && npm --prefix packages/storybook-addon run typecheck && npm --prefix packages/test-components run typecheck",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "clean": "rm -rf dist node_modules packages/*/dist"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-config-standard-with-typescript": "^34.0.1",
    "eslint-plugin-import": "^2.30.0",
    "eslint-plugin-n": "^18.0.1",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^7.2.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "@typescript-eslint/eslint-plugin": "^5.60.1",
    "@typescript-eslint/parser": "^5.60.1",
    "prettier": "^3.0.0",
    "jsdom": "^22.1.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.7",
    "vitest": "^4.1.3"
  }
}
